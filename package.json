{
 "name": "efs",
 "version": "0.4.0",
 "private": true,
 "type": "module",
 "description": "Source-first enterprise management frontend service workspace.",
 "scripts": {
  "build": "vite build --config apps/agentos/vite.config.mjs",
  "check:authoring": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
  "dev:e2e": "vite --config apps/agentos/vite.config.mjs --host 127.0.0.1 --port 4174",
  "test": "vitest run",
  "test:unit": "vitest run",
  "test:e2e": "playwright test",
  "ci": "npm run check:authoring && npm run test && npm run build"
 },
 "engines": {
  "node": ">=20"
 },
 "dependencies": {
  "@babel/parser": "^7.28.4",
  "@mdi/js": "^7.4.47",
  "@playwright/test": "^1.59.1",
  "@types/node": "^25.6.0",
  "@vitejs/plugin-vue": "^5.2.4",
  "@vue/compiler-dom": "^3.5.13",
  "@vue/compiler-sfc": "^3.5.13",
  "@vue/test-utils": "^2.4.6",
  "@vueuse/core": "^14.2.1",
  "jsdom": "^29.0.2",
  "sass": "^1.99.0",
  "typescript": "^5.9.2",
  "vite": "^5.4.19",
  "vite-plugin-vuetify": "^2.1.3",
  "vitest": "^4.1.4",
  "vue": "^3.5.13",
  "vue-i18n": "^9.14.5",
  "vuetify": "^4.0.5"
 }
}
