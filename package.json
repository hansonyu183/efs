{
 "name": "efs",
 "version": "0.4.0",
 "private": true,
 "type": "module",
 "description": "Source-first enterprise management frontend service workspace.",
 "workspaces": [
  "packages/*",
  "apps/*"
 ],
 "scripts": {
  "build": "vite build --config apps/agentos/vite.config.mjs",
  "check:authoring": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
  "lint:schema": "node packages/cli/bin/efs-lint.mjs apps/agentos",
  "test": "node --test",
  "ci": "npm run check:authoring && npm run lint:schema && npm run test && npm run build"
 },
 "engines": {
  "node": ">=20"
 },
 "dependencies": {
  "@babel/parser": "^7.28.4",
  "@vitejs/plugin-vue": "^5.2.4",
  "@vue/compiler-dom": "^3.5.13",
  "@vue/compiler-sfc": "^3.5.13",
  "typescript": "^5.9.2",
  "vite": "^5.4.19",
  "vue": "^3.5.13"
 }
}
