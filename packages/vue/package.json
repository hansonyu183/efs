{
 "name": "@efs/vue",
 "version": "0.4.0",
 "type": "module",
 "private": false,
 "description": "Vue Page/View/Panel components and helpers for enterprise frontend standards.",
 "scripts": {
  "build": "node ./build.mjs"
 },
 "exports": {
  ".": {
   "types": "./dist/index.d.ts",
   "default": "./dist/index.js"
  },
  "./components/*": "./dist/components/*",
  "./shared/*": {
   "types": "./dist/shared/*.d.ts",
   "default": "./dist/shared/*.js"
  },
  "./controller/*": {
   "types": "./dist/controller/*.d.ts",
   "default": "./dist/controller/*.js"
  }
 },
 "files": [
  "dist"
 ],
 "sideEffects": false
}
